<%- include('partials/head', { title: 'Récapitulatif - Vite & Gourmand', bodyClass: '' }) %>
<%- include('partials/header', { page: 'recap-commande' }) %>
<main class="flex-grow-1">
  <section class="hero py-5 text-center text-white" style="background:linear-gradient(rgba(0,0,0,.45),rgba(0,0,0,.45)),url('https://images.unsplash.com/photo-1514933651103-005eec06c04b?w=1600') center/cover;"><div class="container"><h1 class="display-3 fw-bold">Validation</h1></div></section>
  <div class="container py-5"><div id="notificationArea" class="mb-3"></div><div class="row g-4"><div class="col-lg-5"><div class="card p-4 shadow-sm border-0 bg-light h-100"><h3 class="text-primary mb-4 border-bottom pb-2">Votre Sélection</h3><div id="affichageRecap" class="mb-4 small"></div><div class="alert alert-info p-3 mb-3 shadow-sm border-0"><h6 class="fw-bold mb-2"><i class="fas fa-percent me-2"></i>Réductions automatiques</h6><ul class="mb-0 small ps-3"><li>-10% si commande &gt; 100€</li><li>-25% si plus de 6 personnes</li></ul></div><div id="affichageRabais" class="mb-3"></div><hr><div class="d-flex justify-content-between align-items-center"><span class="h5 mb-0 text-muted">Total</span><span class="h2 text-primary fw-bold mb-0" id="totalFinal">0,00 €</span></div></div></div><div class="col-lg-7"><div class="card p-4 shadow border-0 h-100"><h3 class="text-primary mb-4 border-bottom pb-2">Coordonnées</h3><form id="formFinal"><div class="row g-3"><div class="col-md-6"><label class="fw-bold" for="firstName">Prénom</label><input type="text" class="form-control" id="firstName" required></div><div class="col-md-6"><label class="fw-bold" for="lastName">Nom</label><input type="text" class="form-control" id="lastName" required></div><div class="col-12 py-3 bg-light rounded px-3 border"><label class="fw-bold d-block mb-2">Service</label><div class="form-check form-check-inline"><input class="form-check-input" type="radio" name="modeService" id="surPlace" value="surPlace" checked><label class="form-check-label" for="surPlace">🍽️ Sur place</label></div><div class="form-check form-check-inline"><input class="form-check-input" type="radio" name="modeService" id="aEmporter" value="aEmporter"><label class="form-check-label" for="aEmporter">🛍️ À emporter</label></div></div><div class="col-md-6"><label class="fw-bold" for="eventDate">Date</label><input type="date" class="form-control" id="eventDate" required></div><div class="col-md-6"><label class="fw-bold" for="eventTime">Heure</label><input type="time" class="form-control" id="eventTime" required></div><div class="col-md-8"><label class="fw-bold" for="eventStreet">Adresse</label><input type="text" class="form-control" id="eventStreet" required></div><div class="col-md-4"><label class="fw-bold" for="eventCity">Ville</label><input type="text" class="form-control" id="eventCity" value="Bordeaux" required></div><div class="col-md-6"><label class="fw-bold" for="eventZip">Code postal</label><input type="text" class="form-control" id="eventZip" value="33000" required></div><div class="col-md-6"><label class="fw-bold" for="convives">Convives</label><input type="number" class="form-control" id="convives" value="1" min="1" required></div></div><button type="submit" class="btn btn-primary btn-lg w-100 mt-4 shadow fw-bold">CONFIRMER LA COMMANDE</button></form></div></div></div></div>
</main>
<%- include('partials/footer', { extraScripts: [] }) %>
